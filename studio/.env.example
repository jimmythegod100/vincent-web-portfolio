# Studio environment — copy to .env and fill in
COMPOSE_PROJECT_NAME=vm-studio
STUDIO_API_PORT=8000
STUDIO_ENV=development
DATABASE_URL=

# Optional shared Postgres (studio practice)
# When using --profile db, set:
# DATABASE_URL=postgresql+psycopg://studio:studio_dev_change_me@db:5432/studio
POSTGRES_USER=studio
POSTGRES_PASSWORD=studio_dev_change_me
POSTGRES_DB=studio
POSTGRES_PORT=5432
